{
  "name": "pcm-parser",
  "version": "1.2.0",
  "description": "GUI tool to parse raw PCM audio dumps: waveform, spectrogram, preview, and multi-file N-channel WAV export",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node tools/gen-icon.js",
    "dist": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.example.pcmparser",
    "productName": "PCM Parser",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
